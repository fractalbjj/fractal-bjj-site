---
/**
 * Legend for the systems table — explains what the dots,
 * status flags, and counterpart numbers mean.
 */
---

<div class="systems-legend">
  <div class="legend-item">
    <span class="label">Complexity</span>
    <span class="legend-dots">
      <span class="on"></span>
      <span class="on"></span>
      <span></span>
      <span></span>
      <span></span>
    </span>
    <span>1 — 5</span>
  </div>
  <div class="legend-item">
    <span class="label">Status</span>
    <span class="status-list">
      <span>stub</span>
      <span class="dev">in dev</span>
      <span class="live">live</span>
    </span>
  </div>
  <div class="legend-item">
    <span class="label">Counterpart</span>
    <span class="pair-example">
      <span class="pair-arrow">↔</span>
      <span>system no.</span>
    </span>
  </div>
</div>
