---
import '../styles/global.css';
import { siteConfig } from '../data/site';
import Logo from '../components/Logo.astro';
import SearchModal from '../components/SearchModal.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteConfig.defaultTitle,
  description = siteConfig.defaultDescription,
} = Astro.props;

const fullTitle = title === siteConfig.defaultTitle
  ? title
  : `${title} — Fractal BJJ`;

// Determine current path for active nav state
const currentPath = Astro.url.pathname;
const isActive = (path: string) =>
  path === '/' ? currentPath === '/' : currentPath.startsWith(path);
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Manrope:wght@300;400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,300..700;1,8..60,300..700&display=swap" rel="stylesheet" />

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
</head>
<body>

  <header class="site">
    <a href="/" class="wordmark" aria-label="Fractal BJJ — Home">
      <Logo size={30} />
      <span class="name">Fractal <b>BJJ</b></span>
    </a>
    <nav class="primary" data-pagefind-ignore>
      <button id="search-trigger" class="search-nav-btn" type="button" aria-label="Search site">
        <svg class="search-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><circle cx="6.5" cy="6.5" r="4.5"/><line x1="10" y1="10" x2="14" y2="14"/></svg>
      </button>
      <a href="/systems" aria-current={isActive('/systems') ? 'page' : undefined}>Systems</a>
      <a href="/writing" aria-current={isActive('/writing') ? 'page' : undefined}>Writing</a>
      <a href="/approach" aria-current={isActive('/approach') ? 'page' : undefined}>Approach</a>
    </nav>
  </header>

  <div class="status-strip" data-pagefind-ignore>
    <span class="updated">
      <span class="dot"></span>
      Last updated {siteConfig.lastUpdatedDisplay}
    </span>
  </div>

  <main>
    <slot />
  </main>

  <footer class="site" data-pagefind-ignore>
    <div class="footer-grid">
      <div>
        <div class="footer-mark">
          <Logo size={22} />
          <span class="name">Fractal <b>BJJ</b></span>
        </div>
        <p class="colophon">
          A working document built from training, teaching, competition, and the best available sources. <em>Always in progress, never final.</em>
        </p>
      </div>
      <div class="practitioner-line">
        Maintained by one practitioner.
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {new Date().getFullYear()} Fractal BJJ &middot; United Kingdom</span>
      <span>fractal-bjj.com</span>
    </div>
  </footer>


  <SearchModal />
  <script is:inline>
    (function () {
      var previousFocus = null;

      function openSearchModal() {
        var modal = document.getElementById('search-modal');
        if (!modal) return;
        previousFocus = document.activeElement;
        modal.removeAttribute('hidden');
        document.body.style.overflow = 'hidden';
        requestAnimationFrame(function () {
          var input = modal.querySelector('.pagefind-ui__search-input');
          if (input) input.focus();
        });
      }

      function closeSearchModal() {
        var modal = document.getElementById('search-modal');
        if (!modal) return;
        modal.setAttribute('hidden', '');
        document.body.style.overflow = '';
        if (previousFocus) previousFocus.focus();
      }

      document.addEventListener('DOMContentLoaded', function () {
        if (window.PagefindUI) {
          new window.PagefindUI({
            element: '#search',
            showImages: false,
            resetStyles: false,
            showSubResults: true,
          });
        }

        var trigger = document.getElementById('search-trigger');
        if (trigger) trigger.addEventListener('click', openSearchModal);

        var modalEl = document.getElementById('search-modal');
        if (modalEl) {
          modalEl.addEventListener('click', function (e) {
            if (!e.target.closest('#search-panel')) closeSearchModal();
          });
        }

        var panel = document.getElementById('search-panel');
        if (panel) {
          panel.addEventListener('click', function (e) {
            if (e.target.closest && e.target.closest('a[href]')) closeSearchModal();
          });
        }
      });

      window.addEventListener('keydown', function (e) {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          openSearchModal();
        } else if (e.key === 'Escape') {
          var modal = document.getElementById('search-modal');
          if (modal && !modal.hasAttribute('hidden')) closeSearchModal();
        }
      });
    })();
  </script>
</body>
</html>
