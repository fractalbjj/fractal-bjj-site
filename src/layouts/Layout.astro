---
import gitDatesRaw from '../data/git-dates.json';
import BaseHead from '../components/BaseHead.astro';

const gitDates = gitDatesRaw as Record<string, string>;

interface Props {
  title: string;
  description: string;
  lastUpdatedFile?: string;
}

const { title, description, lastUpdatedFile } = Astro.props;

let lastUpdated: string | null = null;
if (lastUpdatedFile) {
  const iso = gitDates[lastUpdatedFile];
  if (iso) {
    const d = new Date(iso);
    lastUpdated = d.toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    });
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding-top: 3.5rem;
        font-family: var(--font-atkinson), Georgia, serif;
        background: #fff;
        color: #1a1a1a;
      }

      header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: #fff;
        border-bottom: 1px solid #e8e8e8;
        padding: 0 2rem;
        transition: transform 0.25s ease;
      }

      header.nav-hidden {
        transform: translateY(-100%);
      }

      header nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 80ch;
        margin: 0 auto;
        height: 3.5rem;
      }

      .site-name {
        font-weight: 700;
        font-size: 1rem;
        text-decoration: none;
        color: inherit;
        letter-spacing: -0.01em;
        white-space: nowrap;
        flex-shrink: 0;
      }

      .nav-links {
        display: flex;
        gap: 2rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .nav-links a {
        font-size: 0.9rem;
        color: #555;
        text-decoration: none;
        white-space: nowrap;
      }

      .nav-links a:hover {
        color: #1a1a1a;
      }

      main {
        width: 100%;
        max-width: 65ch;
        margin: 4rem auto;
        padding: 0 1.5rem;
      }

      @media (max-width: 640px) {
        header {
          padding: 0 1rem;
        }

        .nav-links {
          gap: 1rem;
        }

        .nav-links a {
          font-size: 0.8rem;
        }

        main {
          padding: 0 1rem;
          margin-top: 2rem;
        }

        .last-updated {
          padding: 0 1rem;
        }
      }

      /*
       * max-width uses ch, which is font-relative. Keeping font-size
       * at the default here (not 0.75rem) ensures 65ch matches main's
       * 65ch exactly, so text-align: right lines up with the content edge.
       * The smaller size is applied to the inner <small> element instead.
       */
      .last-updated {
        max-width: 65ch;
        margin: 0 auto 2rem;
        padding: 0 1.5rem;
        text-align: right;
      }

      .last-updated small {
        font-size: 0.75rem;
        color: #bbb;
      }

      footer {
        border-top: 1px solid #e8e8e8;
        text-align: center;
        padding: 2rem 1.5rem;
        font-size: 0.8rem;
        color: #888;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a class="site-name" href="/">Fractal BJJ</a>
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
          <li><a href="/approach">The Approach</a></li>
          <li><a href="/systems">Systems</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    {lastUpdated && (
      <p class="last-updated"><small>Last updated: {lastUpdated}</small></p>
    )}

    <footer>
      Fractal BJJ
    </footer>

    <script>
      const header = document.querySelector('header') as HTMLElement;
      let lastY = window.scrollY;

      window.addEventListener('scroll', () => {
        const y = window.scrollY;
        if (y < lastY) {
          header.classList.remove('nav-hidden');
        } else if (y > lastY && y > 80) {
          header.classList.add('nav-hidden');
        }
        lastY = y;
      }, { passive: true });
    </script>
  </body>
</html>
