---
import '../styles/global.css';
import { siteConfig } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteConfig.defaultTitle,
  description = siteConfig.defaultDescription,
} = Astro.props;

const fullTitle = title === siteConfig.defaultTitle
  ? title
  : `${title} — Fractal BJJ`;

// Determine current path for active nav state
const currentPath = Astro.url.pathname;
const isActive = (path: string) =>
  path === '/' ? currentPath === '/' : currentPath.startsWith(path);
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Manrope:wght@300;400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,300..700;1,8..60,300..700&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="site">
    <a href="/" class="wordmark" aria-label="Fractal BJJ — Home">
      <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <g stroke="#1c1a16" stroke-width="1.4" fill="none" stroke-linejoin="miter">
          <polygon points="50,6 94,82 6,82" />
          <polygon points="50,44 72,82 28,82" />
          <polygon points="50,6 72,44 28,44" />
          <polygon points="28,44 50,82 6,82" />
          <polygon points="72,44 94,82 50,82" />
          <polygon points="50,25 61,44 39,44" />
          <polygon points="39,63 50,82 28,82" />
          <polygon points="61,63 72,82 50,82" />
          <polygon points="50,15 55,25 45,25" />
          <polygon points="45,35 50,44 39,44" />
          <polygon points="55,35 61,44 50,44" />
        </g>
      </svg>
      <span class="name">Fractal <b>BJJ</b></span>
    </a>
    <nav class="primary">
      <a href="/systems" aria-current={isActive('/systems') ? 'page' : undefined}>Systems</a>
      <a href="/writing" aria-current={isActive('/writing') ? 'page' : undefined}>Writing</a>
      <a href="/approach" aria-current={isActive('/approach') ? 'page' : undefined}>Approach</a>
    </nav>
  </header>

  <div class="status-strip">
    <span class="updated">
      <span class="dot"></span>
      Last updated {siteConfig.lastUpdatedDisplay}
    </span>
  </div>

  <main>
    <slot />
  </main>

  <footer class="site">
    <div class="footer-grid">
      <div>
        <div class="footer-mark">
          <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <g stroke="#1c1a16" stroke-width="1.4" fill="none">
              <polygon points="50,6 94,82 6,82" />
              <polygon points="50,44 72,82 28,82" />
              <polygon points="50,6 72,44 28,44" />
              <polygon points="28,44 50,82 6,82" />
              <polygon points="72,44 94,82 50,82" />
            </g>
          </svg>
          <span class="name">Fractal <b>BJJ</b></span>
        </div>
        <p class="colophon">
          A working document built from training, teaching, competition, and the best available sources. <em>Always in progress, never final.</em>
        </p>
      </div>
      <div class="practitioner-line">
        Maintained by one practitioner.
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {new Date().getFullYear()} Fractal BJJ &middot; United Kingdom</span>
      <span>fractal-bjj.com</span>
    </div>
  </footer>

</body>
</html>
