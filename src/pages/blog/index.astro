---
import Layout from '../../layouts/Layout.astro';
import { SITE_TITLE } from '../../consts';
---

<Layout
  title={`Blog — ${SITE_TITLE}`}
  description="Writing on grappling concepts, repository updates, and competitive analysis."
>
  <style>
    h1 {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      line-height: 1.3;
    }

    p {
      line-height: 1.75;
      color: #555;
    }
  </style>

  <h1>Blog</h1>

  <p>
    The blog will live here. First posts coming as the repository takes shape.
  </p>
</Layout>
