---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE } from '../consts';
---

<Layout
  title={`Page not found — ${SITE_TITLE}`}
  description="This page does not exist."
>
  <style>
    h1 {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      line-height: 1.3;
    }

    p {
      line-height: 1.75;
      color: #555;
      margin-bottom: 1rem;
    }

    a {
      color: inherit;
    }
  </style>

  <h1>Page not found</h1>

  <p>
    This page doesn't exist — or does, but shouldn't. Head back to the
    <a href="/systems">system map</a> or the <a href="/">home page</a>.
  </p>
</Layout>
