---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Page not found"
  description="This URL doesn't resolve to a page on Fractal BJJ."
>
  <article class="approach-layout">
    <h1>404 — Page not found</h1>
    <div class="prose">
      <p>This URL doesn't resolve to a page on Fractal BJJ. You may have followed a stale link, or arrived at a system or sub-block that hasn't yet been written — the repository is built page by page and grows over time.</p>
      <p>Try:</p>
      <ul>
        <li><a href="/">The homepage</a></li>
        <li><a href="/systems">Systems index</a></li>
        <li><a href="/writing">Writing</a></li>
        <li>Site search — Cmd/Ctrl-K from anywhere on the site</li>
      </ul>
    </div>
  </article>
</Layout>
