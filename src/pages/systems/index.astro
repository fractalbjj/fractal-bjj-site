---
import Layout from '../../layouts/Layout.astro';
import SystemsList from '../../components/SystemsList.astro';
import SystemsLegend from '../../components/SystemsLegend.astro';
---

<Layout
  title="The System Map"
  description="The full game broken into 19 interconnected systems — offensive, defensive, and general. Each has its own page, growing in depth over time."
>
  <section class="systems" id="systems" data-pagefind-ignore>
    <div class="systems-header">
      <div class="left">
        <span class="eyebrow">The Repository</span>
        <h2>The <em>system</em><br />map.</h2>
      </div>
      <div class="right">
        <p>
          The full scope of high-level no-gi grappling divided into 19 major systems a well-rounded athlete needs competency in. Each has its own page, growing in depth over time.
        </p>
        <p>
          The choice of 19 is mine and it isn't universally agreed — another coach would cut the sport slightly differently.
        </p>
        <p class="systems-index-note">
          A full interactive network diagram showing the 167 directional relationships between systems is in development. For now, the listing below is the structural index.
        </p>
      </div>
      <SystemsLegend />
    </div>

    <SystemsList />
  </section>
</Layout>
