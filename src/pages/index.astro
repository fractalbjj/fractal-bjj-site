---
import Layout from '../layouts/Layout.astro';
import SystemsList from '../components/SystemsList.astro';
import SystemsLegend from '../components/SystemsLegend.astro';
import { getCollection } from 'astro:content';

// Get the 3 most recent blog posts for the homepage writing section
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
---

<Layout
  title="Fractal BJJ"
  description="A systems-thinking approach to high-level no-gi grappling. The full game broken into 19 interconnected systems."
>

  <!-- ================== HERO ================== -->
  <section class="hero">
    <div class="hero-content">
      <h1>Grappling is <em>infinitely</em><br />complex.</h1>
      <div class="lede">
        <p>No document, no course, no system can capture it completely. This isn't a problem that can be solved — it's a starting point.</p>
        <p>Fractal BJJ is an attempt to map high-level No-Gi grappling within a structured repository, in a way a practitioner could actually think about it in real time. The full game is broken into 19 systems, each with an underlying framework of subsystems, concepts and principles.</p>
        <p>This site is how I organise the sport. It's a working document — built from training, teaching, competition, and the best available sources. Always in progress, never final.</p>
      </div>
      <div class="actions">
        <a href="/systems"><span>Enter the system map</span><span class="arrow">→</span></a>
        <a href="/approach"><span>Read the full approach</span><span class="arrow">→</span></a>
        <a></a>
      </div>
    </div>

    <!--
      Network figure: placeholder static SVG.
      Will be replaced by build-time-generated network graphic from
      the relationships data once that pipeline lands (P2 backlog #4).
    -->
    <div class="network-figure">
      <svg viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <g stroke="#7d7466" stroke-width="0.6" fill="none" opacity="0.5">
          <line x1="160" y1="60"  x2="220" y2="100" />
          <line x1="160" y1="60"  x2="100" y2="100" />
          <line x1="220" y1="100" x2="260" y2="160" />
          <line x1="100" y1="100" x2="60"  y2="160" />
          <line x1="160" y1="60"  x2="160" y2="160" />
          <line x1="60"  y1="160" x2="100" y2="220" />
          <line x1="260" y1="160" x2="220" y2="220" />
          <line x1="100" y1="220" x2="160" y2="260" />
          <line x1="220" y1="220" x2="160" y2="260" />
          <line x1="160" y1="160" x2="100" y2="220" />
          <line x1="160" y1="160" x2="220" y2="220" />
          <line x1="220" y1="100" x2="160" y2="160" />
          <line x1="100" y1="100" x2="160" y2="160" />
          <line x1="60"  y1="160" x2="160" y2="160" />
          <line x1="260" y1="160" x2="160" y2="160" />
          <line x1="40"  y1="100" x2="100" y2="100" />
          <line x1="280" y1="100" x2="220" y2="100" />
          <line x1="40"  y1="220" x2="100" y2="220" />
          <line x1="280" y1="220" x2="220" y2="220" />
          <line x1="80"  y1="60"  x2="160" y2="60" />
          <line x1="240" y1="60"  x2="160" y2="60" />
          <line x1="160" y1="110" x2="160" y2="60" />
          <line x1="160" y1="210" x2="160" y2="260" />
        </g>
        <g>
          <circle cx="160" cy="60"  r="6"   fill="#9c2e26" />
          <circle cx="220" cy="100" r="5.5" fill="#9c2e26" />
          <circle cx="100" cy="100" r="5.5" fill="#3a4d5c" />
          <circle cx="260" cy="160" r="5"   fill="#9c2e26" />
          <circle cx="60"  cy="160" r="5"   fill="#3a4d5c" />
          <circle cx="160" cy="160" r="6"   fill="#9c2e26" />
          <circle cx="220" cy="220" r="5"   fill="#3a4d5c" />
          <circle cx="100" cy="220" r="5"   fill="#9c2e26" />
          <circle cx="160" cy="260" r="5.5" fill="#9c2e26" />
          <circle cx="40"  cy="100" r="4"   fill="#3a4d5c" />
          <circle cx="280" cy="100" r="4"   fill="#3a4d5c" />
          <circle cx="40"  cy="220" r="4"   fill="#9c2e26" />
          <circle cx="280" cy="220" r="4"   fill="#3a4d5c" />
          <circle cx="80"  cy="60"  r="4"   fill="#9c2e26" />
          <circle cx="240" cy="60"  r="4"   fill="#9c2e26" />
          <circle cx="80"  cy="260" r="4"   fill="#9c2e26" />
          <circle cx="240" cy="260" r="4"   fill="#3a4d5c" />
          <circle cx="160" cy="110" r="4"   fill="#7d7466" />
          <circle cx="160" cy="210" r="4"   fill="#9c2e26" />
        </g>
      </svg>
      <div class="legend">
        <span class="key"><span class="swatch" style="background: #9c2e26;"></span>Offensive</span>
        <span class="key"><span class="swatch" style="background: #3a4d5c;"></span>Defensive</span>
        <span class="key"><span class="swatch" style="background: #7d7466;"></span>General</span>
      </div>
    </div>
  </section>

  <!-- ================== PULL QUOTE ================== -->
  <section class="pullquote">
    <div class="pullquote-inner">
      <div class="mark">&ldquo;</div>
      <div>
        <blockquote>
          The point of a system isn't to give you more moves. It's to give you a frame for <span>choosing between the ones you already know</span>.
        </blockquote>
        <cite>From "The Approach"</cite>
      </div>
    </div>
  </section>

  <!-- ================== SYSTEMS ================== -->
  <section class="systems" id="systems">
    <div class="systems-header">
      <div class="left">
        <span class="eyebrow">The Repository</span>
        <h2>Nineteen <em>systems,</em><br />organised.</h2>
      </div>
      <div class="right">
        <p>High-level no-gi grappling divided into the 19 systems a well-rounded athlete needs competency in. Each has its own page, growing as understanding deepens. Pages go live at any depth.</p>
      </div>
      <SystemsLegend />
    </div>

    <SystemsList />
  </section>

  <!-- ================== WRITING ================== -->
  <section class="writing" id="writing">
    <div class="writing-inner">
      <div class="writing-side">
        <span class="eyebrow">Writing</span>
        <h2>Recent <em>writing</em></h2>
        <p>Conceptual pieces, repository updates, and analysis of where the sport is heading. The conceptual pieces are where the analytical lens gets applied to BJJ itself.</p>
        <a href="/writing" class="all-link">All writing →</a>
      </div>
      <div class="pieces">
        {posts.map((post) => (
          <article class="piece">
            <div class="meta">
              <span class="category">{post.data.category[0].toUpperCase() + post.data.category.slice(1)}</span>
              <span class="date">{formatDate(post.data.pubDate)}</span>
            </div>
            <div>
              <h4><a href={`/writing/${post.id}`}>{post.data.title}</a></h4>
              <p>{post.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Layout>
